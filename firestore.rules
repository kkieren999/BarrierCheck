rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          currentUserDoc().data.role == "admin"
          || currentUserDoc().data.admin == true
          || currentUserDoc().data.isAdmin == true
        );
    }

    function isSafeOwnProfileUpdate(userId) {
      return isOwner(userId)
        && !request.resource.data.diff(resource.data).changedKeys().hasAny([
          "approved",
          "role",
          "admin",
          "isAdmin",
          "verificationStatus",
          "verificationMethod",
          "verificationNotes",
          "qbccNameMatched",
          "qbccLicenceMatched",
          "qbccCheckedAt",
          "qbccCheckedBy",
          "subscriptionStatus",
          "billingAccess",
          "manualPaid",
          "stripeCustomerId",
          "stripeSubscriptionId",
          "currentPeriodEndsAt",
          "freeInspectionLimit",
          "freeInspectionsUsed",
          "freeInspectionsStartedAt",
          "freeTrialPolicyVersion",
          "freeTrialEligibilityNoticeAccepted",
          "freeTrialEligibilityNoticeAcceptedAt",
          "trialEntitlementCheckStatus",
          "deletionDoesNotResetTrial",
          "approvedAt",
          "approvedBy",
          "verifiedAt",
          "rejectedAt",
          "rejectedBy",
          "rejectionReason",
          "suspendedAt",
          "suspendedBy",
          "suspensionReason",
          "deletionRequestedAt",
          "deletionStatus",
          "emailLog"
        ]);
    }

    match /users/{userId} {
      // User profile creation is handled by the createAccountProfile Cloud Function
      // so free-trial eligibility can be checked server-side with a secret HMAC.
      allow create: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow update: if isSafeOwnProfileUpdate(userId) || isAdmin();
      allow delete: if isAdmin();

      match /inspections/{inspectionId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /email/{emailId} {
      allow create, read, update, delete: if isAdmin();
    }

    // Minimal anti-abuse records for free-trial eligibility.
    // These should contain hashed/minimised identifiers only, not raw licence numbers.
    // Client users cannot read or write them; server/Admin SDK manages them.
    match /trialEntitlements/{entitlementId} {
      allow read, write: if isAdmin();
    }

    // Optional account deletion audit/minimisation records.
    // Client users cannot create or inspect these directly.
    match /accountDeletionRecords/{recordId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
